<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>The 0L Network — Navigate law school admissions together</title>
<meta name="description" content="The community platform for pre-law applicants. Live admissions data, peer application review, and verified mentors — built by an applicant, free for applicants.">
<style>
:root{
  --navy:#101a3a; --navy2:#1b2a5b; --ink:#16203a; --paper:#f7f8fc; --white:#fff;
  --accent:#d8a64a; --accent2:#eebf6a; --muted:#6a7390; --line:#e7eaf3; --teal:#2f8f7f;
  color-scheme:light;
}
*{box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{margin:0;background:var(--paper);color:var(--ink);
  font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;line-height:1.6;}
.wrap{max-width:1080px;margin:0 auto;padding:0 22px;}
a{color:inherit;text-decoration:none;}
h1,h2,h3{line-height:1.18;margin:0;}
nav{position:sticky;top:0;z-index:20;background:rgba(16,26,58,.92);backdrop-filter:blur(8px);color:#fff;}
nav .wrap{display:flex;align-items:center;justify-content:space-between;height:62px;}
.logo{font-weight:800;letter-spacing:.3px;font-size:18px;display:flex;align-items:center;gap:9px;}
.logo .mark{display:inline-grid;place-items:center;width:30px;height:30px;border-radius:8px;
  background:linear-gradient(135deg,var(--accent),var(--accent2));color:var(--navy);font-weight:900;font-size:14px;}
.nav-cta{background:var(--accent);color:var(--navy);font-weight:700;padding:9px 16px;border-radius:9px;font-size:14px;}
.nav-cta:hover{background:var(--accent2);}
.hero{background:radial-gradient(1200px 500px at 70% -10%,#27407f 0%,var(--navy) 55%);color:#fff;padding:74px 0 84px;}
.badge{display:inline-block;font-size:12px;font-weight:700;letter-spacing:.6px;text-transform:uppercase;
  color:var(--accent2);border:1px solid rgba(238,191,106,.4);border-radius:999px;padding:5px 13px;margin-bottom:20px;}
.hero h1{font-size:46px;font-weight:800;max-width:15ch;}
.hero p.sub{font-size:19px;color:#c5cce6;max-width:52ch;margin:18px 0 28px;}
.form{display:flex;gap:10px;flex-wrap:wrap;max-width:480px;}
.form input{flex:1;min-width:220px;padding:14px 15px;border-radius:11px;border:1px solid #36447a;
  background:#0c1430;color:#fff;font-size:15px;}
.form input::placeholder{color:#8b96bd;}
.form button{padding:14px 22px;border-radius:11px;border:none;cursor:pointer;font-size:15px;font-weight:800;
  background:linear-gradient(135deg,var(--accent),var(--accent2));color:var(--navy);}
.form button:hover{filter:brightness(1.05);}
.hero .fine{font-size:13px;color:#9aa4cb;margin-top:12px;}
.msg{margin-top:14px;font-size:15px;font-weight:600;display:none;}
.msg.ok{color:#7be0c0;display:block;}
.msg.err{color:#ff9b9b;display:block;}
.count{margin-top:22px;font-size:14px;color:#c5cce6;display:flex;align-items:center;gap:8px;}
.count b{color:#fff;}
.dot{width:8px;height:8px;border-radius:50%;background:#7be0c0;box-shadow:0 0 0 4px rgba(123,224,192,.18);}
section{padding:64px 0;}
.kicker{font-size:13px;font-weight:800;letter-spacing:1px;text-transform:uppercase;color:var(--teal);}
h2.title{font-size:32px;font-weight:800;margin:10px 0 8px;max-width:20ch;}
.lead{color:var(--muted);font-size:17px;max-width:62ch;}
.grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-top:34px;}
.card{background:var(--white);border:1px solid var(--line);border-radius:16px;padding:22px;
  box-shadow:0 4px 18px rgba(20,30,70,.05);}
.card .ic{width:42px;height:42px;border-radius:11px;display:grid;place-items:center;font-size:20px;
  background:#eef1fb;margin-bottom:14px;}
.card h3{font-size:18px;margin-bottom:7px;}
.card p{color:var(--muted);font-size:15px;margin:0;}
.tag{display:inline-block;font-size:11px;font-weight:700;color:var(--teal);background:#e6f4f0;border-radius:6px;padding:2px 8px;margin-top:12px;}
.alt{background:var(--navy);color:#fff;}
.alt .lead{color:#bcc4e4;}
.steps{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:34px;}
.step{background:#15224d;border:1px solid #2a3a6e;border-radius:16px;padding:22px;}
.step .n{font-size:13px;font-weight:800;color:var(--accent2);letter-spacing:1px;}
.step h3{font-size:18px;margin:8px 0 7px;}
.step p{color:#bcc4e4;font-size:15px;margin:0;}
.compare{margin-top:30px;border:1px solid var(--line);border-radius:16px;overflow:hidden;background:#fff;}
.compare .row{display:grid;grid-template-columns:1.4fr 1fr 1fr;border-top:1px solid var(--line);}
.compare .row:first-child{border-top:none;background:#f1f4fc;font-weight:700;font-size:14px;}
.compare .cell{padding:13px 16px;font-size:14.5px;}
.compare .row .cell:nth-child(2){color:var(--muted);}
.compare .row .cell:nth-child(3){color:var(--navy);font-weight:600;background:#fbf6ec;}
.yes{color:var(--teal);font-weight:800;}.no{color:#c2542f;font-weight:800;}
.founder{background:#fff;border:1px solid var(--line);border-radius:18px;padding:30px;display:flex;gap:22px;align-items:flex-start;}
.founder .av{width:54px;height:54px;border-radius:50%;flex:none;background:linear-gradient(135deg,var(--navy2),var(--teal));display:grid;place-items:center;color:#fff;font-weight:800;font-size:20px;}
.founder p{margin:0 0 10px;font-size:16px;color:#2c3550;}
.founder .who{font-size:14px;color:var(--muted);font-weight:600;}
.final{background:linear-gradient(135deg,var(--navy),#27407f);color:#fff;border-radius:22px;padding:46px;text-align:center;}
.final h2{font-size:30px;font-weight:800;}
.final p{color:#c5cce6;max-width:46ch;margin:12px auto 24px;}
.final .form{margin:0 auto;justify-content:center;}
footer{padding:34px 0;color:var(--muted);font-size:14px;text-align:center;}
@media(max-width:820px){
  .hero h1{font-size:34px;}.grid,.steps{grid-template-columns:1fr;}
  .compare .row{grid-template-columns:1.2fr 1fr 1fr;}
  .founder{flex-direction:column;}.final{padding:32px 20px;}
}
</style>
</head>
<body>

<nav><div class="wrap">
  <div class="logo"><span class="mark">0L</span> The 0L Network</div>
  <a href="#join" class="nav-cta">Join the waitlist</a>
</div></nav>

<header class="hero"><div class="wrap">
  <span class="badge">Now forming the first cohort</span>
  <h1>Navigate law school admissions together.</h1>
  <p class="sub">The community for pre-law applicants. See where you really stand with live admissions data, get your application torn apart by people who have done it, and talk to current law students who were in your seat last year.</p>
  <form class="form" id="form-top" novalidate>
    <input type="email" id="email-top" placeholder="you@university.edu" aria-label="Email address" required>
    <button type="submit">Get early access</button>
  </form>
  <div class="msg" id="msg-top"></div>
  <div class="fine">Free for applicants. Built by an applicant, not a consulting firm.</div>
  <div class="count"><span class="dot"></span> <b id="count">312</b>&nbsp;applicants on the waitlist</div>
</div></header>

<section><div class="wrap">
  <div class="kicker">The problem</div>
  <h2 class="title">Applying to law school is lonely, expensive, and full of guesswork.</h2>
  <p class="lead">You are juggling the LSAT, a GPA you cannot change, personal statements, recommenders, and a dozen deadlines, mostly alone. The advice is scattered across anonymous forums and outdated PDFs, the good help costs thousands, and nobody can tell you whether your numbers actually give you a shot at your dream school. The 0L Network puts the whole cycle, and the people going through it with you, in one place.</p>
</div></section>

<section style="padding-top:0;"><div class="wrap">
  <div class="kicker">What you get</div>
  <h2 class="title">Three things no anonymous forum can give you.</h2>
  <div class="grid">
    <div class="card">
      <div class="ic">📊</div>
      <h3>Live admissions tracker</h3>
      <p>Real applicants log their stats, acceptances, and scholarship offers in real time. See exactly where your LSAT and GPA land at every school, and spot splitter and reverse-splitter paths.</p>
      <span class="tag">Crowdsourced &amp; current</span>
    </div>
    <div class="card">
      <div class="ic">✍️</div>
      <h3>Peer application review</h3>
      <p>Get your personal statement, resume, and addenda reviewed against real rubrics. Review someone else's to earn credits toward your own. Honest feedback, not flattery.</p>
      <span class="tag">Give-to-get</span>
    </div>
    <div class="card">
      <div class="ic">🎓</div>
      <h3>Verified mentors</h3>
      <p>Talk to current law students and recent admits who were in your exact position last cycle. Ask the awkward questions you cannot ask an admissions office.</p>
      <span class="tag">Been-there guidance</span>
    </div>
  </div>
</div></section>

<section class="alt"><div class="wrap">
  <div class="kicker" style="color:var(--accent2)">How it works</div>
  <h2 class="title" style="color:#fff">A loop that gets more useful the more you put in.</h2>
  <p class="lead">Every applicant who joins makes the data sharper and the feedback faster for everyone else.</p>
  <div class="steps">
    <div class="step"><div class="n">STEP 1</div><h3>Build your profile</h3><p>Add your stats and the schools you are targeting. Instantly see how you stack up against this cycle's real applicants.</p></div>
    <div class="step"><div class="n">STEP 2</div><h3>Give to get</h3><p>Review a peer's essay or share your results, and earn credits toward feedback on your own application and time with a mentor.</p></div>
    <div class="step"><div class="n">STEP 3</div><h3>Move through the cycle</h3><p>Track deadlines and decisions, compare offers when they arrive, and help the next cohort with what you learned.</p></div>
  </div>
</div></section>

<section><div class="wrap">
  <div class="kicker">Why it is different</div>
  <h2 class="title">Structured and real, not anonymous chaos.</h2>
  <div class="compare">
    <div class="row"><div class="cell">&nbsp;</div><div class="cell">Forums &amp; data sites</div><div class="cell">The 0L Network</div></div>
    <div class="row"><div class="cell">Live, structured admissions data</div><div class="cell">Scattered</div><div class="cell"><span class="yes">Built in</span></div></div>
    <div class="row"><div class="cell">Real application feedback</div><div class="cell"><span class="no">Rare</span></div><div class="cell"><span class="yes">Rubric-based</span></div></div>
    <div class="row"><div class="cell">Verified current-student mentors</div><div class="cell"><span class="no">No</span></div><div class="cell"><span class="yes">Yes</span></div></div>
    <div class="row"><div class="cell">Free for applicants</div><div class="cell">Mixed</div><div class="cell"><span class="yes">Always</span></div></div>
  </div>
</div></section>

<section style="padding-top:0;"><div class="wrap">
  <div class="founder">
    <div class="av">K</div>
    <div>
      <p>"I am applying this cycle. I have lived the lonely spreadsheets, the scattered Reddit advice, and the question nobody could answer: do my numbers actually give me a shot? I am building the platform I wish existed, with the people who need it. Join us early and help shape it."</p>
      <div class="who">— Founder, current law school applicant</div>
    </div>
  </div>
</div></section>

<section id="join"><div class="wrap">
  <div class="final">
    <h2>Be in the first cohort.</h2>
    <p>Early members get free lifetime access to the community and a say in what we build first.</p>
    <form class="form" id="form-bottom" novalidate>
      <input type="email" id="email-bottom" placeholder="you@university.edu" aria-label="Email address" required>
      <button type="submit">Join the waitlist</button>
    </form>
    <div class="msg" id="msg-bottom"></div>
  </div>
</div></section>

<footer><div class="wrap">The 0L Network · A community for pre-law applicants · © 2026</div></footer>

<script>
/* ============================================================
   EMAIL CAPTURE SETUP
   To collect real emails, create a free form at https://formspree.io
   (takes 2 minutes), then paste your endpoint URL below, e.g.
   const ENDPOINT = "https://formspree.io/f/abcdwxyz";
   Leave it as "" to demo the page without saving emails.
   ============================================================ */
const ENDPOINT = "https://formspree.io/f/xkolbjqk";

let count = 312;
function isEmail(v){ return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v); }

function wire(formId, inputId, msgId){
  const form = document.getElementById(formId);
  const input = document.getElementById(inputId);
  const msg = document.getElementById(msgId);
  form.addEventListener("submit", async function(e){
    e.preventDefault();
    const email = input.value.trim();
    if(!isEmail(email)){
      msg.className = "msg err"; msg.textContent = "Please enter a valid email address.";
      return;
    }
    msg.className = "msg"; msg.style.display="none";
    try{
      if(ENDPOINT){
        const r = await fetch(ENDPOINT, {method:"POST",headers:{"Accept":"application/json"},
          body:(()=>{const f=new FormData();f.append("email",email);return f;})()});
        if(!r.ok) throw new Error("net");
      }
      msg.className = "msg ok";
      msg.textContent = "You are on the list. We will be in touch as the first cohort forms.";
      input.value = "";
      count++; document.getElementById("count").textContent = count;
    }catch(err){
      msg.className = "msg err";
      msg.textContent = "Something went wrong. Please try again.";
    }
  });
}
wire("form-top","email-top","msg-top");
wire("form-bottom","email-bottom","msg-bottom");
</script>
</body>
</html>
